{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "api/data/**",
          "api/prompts/**",
          "api/fonts/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "client/static/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|ico|json|txt|svg|webp|woff|woff2|ttf|eot|map))",
      "dest": "client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}
